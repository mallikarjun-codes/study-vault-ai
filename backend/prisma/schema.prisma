generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(uuid())
  name         String
  email        String          @unique
  passwordHash String
  createdAt    DateTime        @default(now())
  documents    Document[]
  chunks       DocumentChunk[]
  chatSessions ChatSession[]
}

model Document {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  mimeType   String
  status     String          @default("PENDING") // PENDING, PROCESSING, COMPLETED, READY, FAILED
  fileSize   Int?
  textLength Int?
  createdAt  DateTime        @default(now())
  chunks     DocumentChunk[]
}

model DocumentChunk {
  id               String   @id @default(uuid())
  documentId       String
  document         Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content          String
  chunkIndex       Int
  pageNumber       Int?
  pineconeVectorId String?  // Reference ID to the vector stored in Pinecone
  createdAt        DateTime @default(now())

  @@index([documentId])
  @@index([userId])
}

model ChatSession {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String    @default("New Chat")
  createdAt DateTime  @default(now())
  messages  Message[]

  @@index([userId])
}

model Message {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user" or "assistant"
  content   String
  sources   Json?
  createdAt DateTime    @default(now())

  @@index([sessionId])
}
